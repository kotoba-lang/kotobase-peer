 ;; own deps.edn.
 :deps {io.github.kotoba-lang/kqe        {:git/sha "44d5c2ae6b44143815a6bddca6154dd0b7198129"}
        io.github.kotoba-lang/commit-dag {:git/sha "ad91b17c0d0b808b60ce68b2ee5fbfa811f40f5d"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}}}
