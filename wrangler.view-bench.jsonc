{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kotobase-view-bench",
  "main": "bench/r2_view_bench_worker.js",
  "compatibility_date": "2026-07-21",
  "assets": {
    "directory": "./out/view-e2e",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "r2_buckets": [
    {
      "binding": "MERKLE_BUCKET",
      "bucket_name": "kotobase-merkle-lsm"
    }
  ]
}
